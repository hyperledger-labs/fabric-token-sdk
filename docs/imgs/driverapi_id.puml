@startuml
skinparam componentStyle rectangle

title Token SDK Driver API - Identity & Wallets

package "Identity & Wallets" {
    interface WalletService {
        + OwnerWallet(id: WalletLookupID): OwnerWallet
        + IssuerWallet(id: WalletLookupID): IssuerWallet
        + AuditorWallet(id: WalletLookupID): AuditorWallet
        + CertifierWallet(id: WalletLookupID): CertifierWallet
        + SpendIDs(ids ...*token.ID): ([]string, error)
    }

    interface IdentityProvider {
        + GetSigner(identity: Identity): Signer
        + RegisterSigner(identity: Identity, signer: Signer, verifier: Verifier, signerInfo: []byte, ephemeral: bool): error
        + GetAuditInfo(identity: Identity): []byte
        + IsMe(party: Identity): bool
        + Bind(longTerm: Identity, ephemeralIdentities ...Identity): error
    }

    interface Deserializer {
        + GetOwnerVerifier(id: Identity): Verifier
        + GetIssuerVerifier(id: Identity): Verifier
        + GetAuditorVerifier(id: Identity): Verifier
        + Recipients(raw: Identity): []Identity
        + MatchIdentity(id: Identity, ai: []byte): error
    }

    interface OwnerWallet {
        + ID(): string
        + GetRecipientIdentity(): (Identity, error)
        + ListTokens(opts: *ListTokensOptions): (*token.UnspentTokens, error)
        + Balance(opts: *ListTokensOptions): (uint64, error)
    }

    WalletService ..> OwnerWallet : provides
}

@enduml
